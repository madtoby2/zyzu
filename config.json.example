{
  "api_key": "your-secret-key-here",
  "bot_token": "YOUR_BOT_TOKEN_HERE",
  "channel_id": -1001234567890,
  "scrape_cron": "0 0 */6 * * *",
  "content_cron": "0 8,20 * * *",
  "content_mode": "video",
  "content_limit": 5,
  "listen_addr": ":8080",
  "post_format": "📡 *{name}*  |  {availability}  |  {resource_count}条  |  {response_time}\n🏷 {tags}\n🔗 `{api_url}`"
}
