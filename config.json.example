{
  "api_key": "your-secret-key",
  "bot_token": "YOUR_BOT_TOKEN_HERE",
  "channel_map": {
    "default": [-1001234567890],
    "adult": [-1001111111],
    "movie": [-1002222222],
    "anime": [-1003333333]
  },
  "scrape_cron": "0 0 */6 * * *",
  "content_cron": "0 8,20 * * *",
  "content_mode": "video",
  "content_limit": 10,
  "listen_addr": ":8080",
  "post_format": "📡 *{name}*  |  {availability}  |  {resource_count}条  |  {response_time}\n🏷 {tags}\n🔗 `{api_url}`"
}
